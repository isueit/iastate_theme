{# IPIC Resource View with drawer slider #}
<div class="resource-group">
  {% if title %}
    <h3 class="resource-group__title">{{ title }}</h3>
  {% endif %}
  {% for row in rows %}
    <div{{ row.attributes.addClass('views-row') }}>
      {{ row.content }}
    </div>
  {% endfor %}
  <div class="resource-drawer-panel" aria-hidden="true" role="dialog" aria-label="Resource details">
    <div class="resource-drawer-panel__inner">
      <button class="resource-drawer-panel__close" aria-label="Close details">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
      <p class="resource-panel-label">Resource Detail</p>
      <div class="resource-drawer-panel__content"></div>
    </div>
  </div>
  <div class="resource-drawer-overlay" aria-hidden="true"></div>
</div>